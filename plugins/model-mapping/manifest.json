{
  "name": "model-mapping",
  "version": "1.0.0",
  "builtin": true,
  "schemaVersion": 2,
  "artifactKind": "runtime-plugin",
  "main": "server/index.ts",
  "capabilities": ["hooks", "dynamicRuntimeLoad"],
  "uiExtensionMode": "none",
  "engines": {
    "bungee": "^3.2.0"
  },
  "metadata": {
    "name": "metadata.name",
    "description": "plugin.description",
    "icon": "compare_arrows"
  },
  "configSchema": [
    {
      "name": "modelMappings",
      "type": "model_mapping",
      "label": "modelMapping.label",
      "description": "modelMapping.description",
      "placeholder": "modelMapping.placeholder",
      "catalogPlugin": "model-mapping"
    }
  ],
  "contributes": {
    "settings": "/catalog"
  },
  "translations": {
    "en": {
      "metadata.name": "Model Mapping",
      "plugin.description": "Standalone model mapping plugin with manual model catalog refresh and offline fallback",
      "modelMapping.label": "Model Mapping",
      "modelMapping.description": "Map source models to target models. Uses the manually refreshed stored catalog, or Tokenlens offline data before the first refresh.",
      "modelMapping.placeholder": "Add source and target model mapping",
      "modelMapping.sourceLabel": "Source model",
      "modelMapping.targetLabel": "Target model",
      "modelMapping.sourceProviderFilter": "Source provider filter",
      "modelMapping.targetProviderFilter": "Target provider filter",
      "modelMapping.allProviders": "All providers",
      "modelMapping.addRow": "Add mapping",
      "modelMapping.empty": "No model mappings configured"
    },
    "zh-CN": {
      "metadata.name": "模型映射",
      "plugin.description": "独立的模型映射插件，支持手动刷新模型目录并提供离线兜底",
      "modelMapping.label": "模型映射",
      "modelMapping.description": "将源模型映射到目标模型。优先使用手动刷新后保存的目录；首次未刷新时使用 Tokenlens 离线数据。",
      "modelMapping.placeholder": "添加源模型与目标模型映射",
      "modelMapping.sourceLabel": "源模型",
      "modelMapping.targetLabel": "目标模型",
      "modelMapping.sourceProviderFilter": "源模型提供商筛选",
      "modelMapping.targetProviderFilter": "目标模型提供商筛选",
      "modelMapping.allProviders": "全部提供商",
      "modelMapping.addRow": "添加映射",
      "modelMapping.empty": "尚未配置模型映射"
    }
  }
}
